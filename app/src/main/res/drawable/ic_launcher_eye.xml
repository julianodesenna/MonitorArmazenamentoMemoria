<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="315"
                android:startColor="#07111F"
                android:centerColor="#0C1F3A"
                android:endColor="#050A12"/>
            <corners android:radius="22dp"/>
            <stroke
                android:width="1dp"
                android:color="#203B6B"/>
        </shape>
    </item>

    <item android:left="8dp" android:top="8dp" android:right="8dp" android:bottom="8dp">
        <shape android:shape="oval">
            <gradient
                android:angle="0"
                android:startColor="#102A4A"
                android:endColor="#081320"/>
            <stroke
                android:width="1dp"
                android:color="#2F69C9"/>
        </shape>
    </item>

    <item android:left="12dp" android:top="20dp" android:right="12dp" android:bottom="20dp">
        <shape android:shape="oval">
            <gradient
                android:angle="0"
                android:startColor="#2CE6FF"
                android:centerColor="#1A86FF"
                android:endColor="#7D52FF"/>
            <size android:height="42dp"/>
        </shape>
    </item>

    <item android:left="18dp" android:top="25dp" android:right="18dp" android:bottom="25dp">
        <shape android:shape="oval">
            <solid android:color="#07111F"/>
            <size android:height="32dp"/>
        </shape>
    </item>

    <item android:left="28dp" android:top="28dp" android:right="28dp" android:bottom="28dp">
        <shape android:shape="oval">
            <gradient
                android:angle="0"
                android:startColor="#19F3FF"
                android:endColor="#4F68FF"/>
            <size android:width="18dp" android:height="18dp"/>
        </shape>
    </item>

    <item android:left="34dp" android:top="34dp" android:right="34dp" android:bottom="34dp">
        <shape android:shape="oval">
            <solid android:color="#041018"/>
        </shape>
    </item>

    <item android:left="26dp" android:top="26dp" android:right="26dp" android:bottom="26dp">
        <shape android:shape="ring"
            android:innerRadius="10dp"
            android:thickness="3dp"
            android:useLevel="false">
            <solid android:color="#57EAFF"/>
        </shape>
    </item>

    <item android:left="20dp" android:top="10dp">
        <shape android:shape="oval">
            <size android:width="10dp" android:height="10dp"/>
            <solid android:color="#40FFFFFF"/>
        </shape>
    </item>
</layer-list>

<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="315"
                android:startColor="#FFF4D0"
                android:endColor="#FFE2A1"/>
            <corners android:radius="18dp"/>
            <stroke
                android:width="1dp"
                android:color="#F0B94D"/>
        </shape>
    </item>

    <item android:left="10dp" android:top="8dp" android:right="40dp" android:bottom="10dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="0"
                android:startColor="#9AABB8"
                android:centerColor="#DDE5EA"
                android:endColor="#7E919E"/>
            <corners android:radius="10dp"/>
            <stroke android:width="1dp" android:color="#6B7C88"/>
        </shape>
    </item>

    <item android:left="38dp" android:top="8dp" android:right="10dp" android:bottom="10dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="0"
                android:startColor="#8F9FAA"
                android:centerColor="#D9E2E8"
                android:endColor="#728592"/>
            <corners android:radius="10dp"/>
            <stroke android:width="1dp" android:color="#6B7C88"/>
        </shape>
    </item>

    <item android:left="10dp" android:top="12dp" android:right="40dp">
        <shape android:shape="rectangle">
            <size android:height="6dp"/>
            <solid android:color="#5A6D78"/>
        </shape>
    </item>

    <item android:left="38dp" android:top="12dp" android:right="10dp">
        <shape android:shape="rectangle">
            <size android:height="6dp"/>
            <solid android:color="#5A6D78"/>
        </shape>
    </item>

    <item android:left="18dp" android:top="36dp" android:right="18dp" android:bottom="14dp">
        <shape android:shape="rectangle">
            <solid android:color="#D39B3D"/>
            <corners android:radius="4dp"/>
        </shape>
    </item>
</layer-list>

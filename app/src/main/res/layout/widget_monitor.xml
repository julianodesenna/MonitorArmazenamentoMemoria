<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widgetRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="#FFFFFF">

    <TextView
        android:id="@+id/widgetTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Monitor"
        android:textStyle="bold"
        android:textSize="15sp"
        android:textColor="#0E1A38" />

    <TextView
        android:id="@+id/widgetStorage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="ARM 0%"
        android:textStyle="bold"
        android:textSize="15sp"
        android:textColor="#FFC107"
        android:layout_marginTop="8dp" />

    <TextView
        android:id="@+id/widgetMemory"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="RAM 0%"
        android:textStyle="bold"
        android:textSize="15sp"
        android:textColor="#3AC94E"
        android:layout_marginTop="4dp" />

    <TextView
        android:id="@+id/widgetFree"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Livre: --"
        android:textSize="12sp"
        android:textColor="#455064"
        android:layout_marginTop="6dp" />

    <TextView
        android:id="@+id/widgetUpdated"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="toque para abrir"
        android:textSize="11sp"
        android:textColor="#235CAA"
        android:layout_marginTop="3dp" />

</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widgetRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="14dp"
    android:background="#FFFFFF">

    <TextView
        android:id="@+id/widgetTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Monitor do aparelho"
        android:textStyle="bold"
        android:textSize="16sp"
        android:textColor="#0E1A38" />

    <TextView
        android:id="@+id/widgetStorage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Armaz. 0%"
        android:textStyle="bold"
        android:textSize="15sp"
        android:textColor="#0E1A38"
        android:layout_marginTop="10dp" />

    <ProgressBar
        android:id="@+id/widgetStorageBar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="10dp"
        android:max="100"
        android:progress="0"
        android:layout_marginTop="4dp" />

    <TextView
        android:id="@+id/widgetMemory"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="RAM 0%"
        android:textStyle="bold"
        android:textSize="15sp"
        android:textColor="#0E1A38"
        android:layout_marginTop="10dp" />

    <ProgressBar
        android:id="@+id/widgetMemoryBar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="10dp"
        android:max="100"
        android:progress="0"
        android:layout_marginTop="4dp" />

    <TextView
        android:id="@+id/widgetFree"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Livre: --"
        android:textSize="13sp"
        android:textColor="#455064"
        android:layout_marginTop="10dp" />

    <TextView
        android:id="@+id/widgetUpdated"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Atualizado agora"
        android:textSize="12sp"
        android:textColor="#235CAA"
        android:layout_marginTop="4dp" />

    <TextView
        android:id="@+id/widgetRefresh"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="↻ Toque para atualizar"
        android:textSize="12sp"
        android:textColor="#235CAA"
        android:gravity="center"
        android:layout_marginTop="8dp"
        android:padding="6dp" />

</LinearLayout>
